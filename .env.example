# === API Keys ===

# OpenAI (requerida para embeddings, opcional para generacion)
OPENAI_API_KEY=sk-...

# Cohere (requerida para reranking)
COHERE_API_KEY=...

# OpenRouter (opcional, para modelos alternativos como arcee-ai/trinity-large-thinking)
# Obtenla en: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# === Tracing / Observabilidad (opcional) ===
#
# Langfuse: traces de cada query con LLM calls, retrieval, rerank, tokens, costos.
# Plan free: 50k observaciones/mes en cloud.langfuse.com
# Self-hosted: ver docker-compose.langfuse.yml
#
# Si dejas estas dos variables vacias, el tracing queda desactivado y no se hace
# ninguna llamada de red — util para desarrollo offline.
#
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com   # default; cambia para self-hosted
